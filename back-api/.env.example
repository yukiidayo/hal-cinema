# MySQL (Docker Compose)
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=hal_cinema
MYSQL_USER=hal_user
MYSQL_PASSWORD=hal_pass
TZ=Asia/Tokyo

# DB connection (back-api)
DB_HOST=localhost
DB_PORT=3306
DB_USER=hal_user
DB_PASSWORD=hal_pass
DB_NAME=hal_cinema

# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@hal-cinema.example.jp

# Site
BASE_URL=http://localhost:5173
# Image server
IMAGE_BASE_URL=http://localhost:3001
