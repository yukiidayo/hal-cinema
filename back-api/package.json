{
  "name": "back-api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:up": "docker compose -f docker-compose.yml up -d",
    "db:down": "docker compose -f docker-compose.yml down",
    "db:logs": "docker compose -f docker-compose.yml logs -f mysql",
    "db:reset": "docker compose -f docker-compose.yml down -v",
    "db:migrate": "echo 'Schema is initialized automatically on db:up (Docker initdb.d)'"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.15",
    "mysql2": "^3.22.3",
    "resend": "^6.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
